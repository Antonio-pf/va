# Resend API Key para envio de e-mails
# Crie uma conta em https://resend.com e gere uma API Key
RESEND_API_KEY=re_sua_chave_aqui

# Destinatários dos e-mails de contato (separe em variáveis distintas)
# Em modo de teste o Resend só envia para o e-mail da própria conta
# Em produção, verifique um domínio em https://resend.com/domains
CONTACT_EMAIL_1=seu_email_principal@exemplo.com
CONTACT_EMAIL_2=segundo_email@exemplo.com
